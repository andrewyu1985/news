{
  "manifest_version": 3,
  "name": "News Digest Collector",
  "version": "1.0",
  "description": "Собирает вкладки Perplexity для дайджеста новостей",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "News Digest",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
